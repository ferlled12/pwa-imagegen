{
  "version": 2,
  "public": true,
  "buildCommand": null,
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
